#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Prevent committing .env files (allow .env.example)
ENV_FILES=$(git diff --cached --name-only | grep '\.env' | grep -v '\.env\.example' || true)
if [ -n "$ENV_FILES" ]; then
  echo "Error: Attempting to commit .env files:"
  echo "$ENV_FILES"
  echo "Please unstage them with: git reset HEAD <file>"
  exit 1
fi
